meta {
  name: POST auth-token
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  { "email": "{{test_user_email}}", "password": "{{test_user_password}}" }
}

script:post-response {
  bru.setVar("auth_token", res.body.accessToken);
}
